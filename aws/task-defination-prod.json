{
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "family": "LearnJenkinsApp-TaskDefination-Prod",
    "containerDefinitions": [
        {
            "name": "learnjenkinsapp",
            "image": "671544340936.dkr.ecr.ap-south-1.amazonaws.com/learn-jenkins-app:#APP_VERSION#",
            "portMappings": [
                {
                    "name": "nginx-80-tcp",
                    "containerPort": 80,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true
        }
    ],
    "volumes": [],
    "networkMode": "awsvpc",
    "memory": "512",
    "cpu": "256",
    "executionRoleArn": "arn:aws:iam::671544340936:role/ecsTaskExecutionRole"
}